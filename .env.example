PREMIUM_DURATION_DAYS=30

# === Push-уведомления ===
PUSH_COOLDOWN_HOURS=4
CHANNEL_INTERVAL_SEC=1800

# === API ===
ALLOWED_ORIGINS=*
PORT=8080
