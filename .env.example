# === Скопируй в .env и подставь реальные значения ===

# === Telegram Bot ===
# Токен от @BotFather (НЕ КОММИТЬ в git!)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# === БД ===
# SQLite (для dev / Render Web Service с persistent disk)
USE_SQLITE=true
# PostgreSQL (для prod, опционально):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# === Админы (через запятую) ===
ADMIN_USERNAMES=darkt30
ADMIN_IDS=

# === Mini App (после деплоя на Vercel) ===
# Замени на свой URL из Vercel
MINI_APP_URL=https://benzin-mini.vercel.app

# === Канал автопубликации ===
# chat_id канала (например -1001234567890). Узнать через @userinfobot или getChat
# Бот должен быть админом канала с правом post_messages
CHANNEL_CHAT_ID=

# === Premium (Telegram Stars) ===
PREMIUM_PRICE_STARS=149
PREMIUM_DURATION_DAYS=30

# === Внешние источники цен ===
# 2ГИС Catalog API: https://dev.2gis.ru/ → API key (free: 1000 req/day)
TWO_GIS_API_KEY=
# Telegram API для парсинга каналов с ценами (https://my.telegram.org)
TG_API_ID=
TG_API_HASH=

# === Push-уведомления ===
PUSH_COOLDOWN_HOURS=4
CHANNEL_INTERVAL_SEC=1800

# === API ===
ALLOWED_ORIGINS=*
PORT=8080

# === Внешние источники цен (новое) ===
# Яндекс.Заправки API (25k req/мес free): https://developer.tech.yandex.ru/services/3
YANDEX_GEOCODER_API_KEY=
