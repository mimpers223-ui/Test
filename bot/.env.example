# =====================================================
# «Бензин рядом» — шаблон конфигурации
# Скопируй в .env и заполни реальными значениями
# НЕ коммить .env в git — только .env.example
# =====================================================

# Токен Telegram-бота (получи у @BotFather)
BOT_TOKEN=

# Использовать SQLite (true) или PostgreSQL (false)
# SQLite = локальная разработка
# PostgreSQL = продакшен (Supabase)
USE_SQLITE=true

# Строка подключения к PostgreSQL (Supabase)
# Settings → Database → Connection string → Transaction mode (port 6543)
DATABASE_URL=

# Telegram ID админов (через запятую)
# Эти пользователи получат доступ к /moderate для одобрения владельцев АЗС
# Чтобы узнать свой ID, отправь боту команду /my_id
ADMIN_IDS=

# Telegram username'ы админов (опционально, через запятую, без @)
# Альтернатива ADMIN_IDS — удобно для настройки
ADMIN_USERNAMES=

# Chat ID канала для автопубликации отчётов (опционально)
# Создай канал, добавь бота админом, впиши chat_id сюда.
# Формат: -100xxxxxxxxx (для каналов начинается с минуса)
CHANNEL_CHAT_ID=

# === Парсер Telegram-каналов (опционально) ===
# Получи на https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=

