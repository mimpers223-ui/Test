# =====================================================
# «Бензин рядом» — шаблон конфигурации
# Скопируй в .env и заполни реальными значениями
# НЕ коммить .env в git — только .env.example
# =====================================================

# Токен Telegram-бота (получи у @BotFather)
BOT_TOKEN=

# Использовать SQLite (true) или PostgreSQL (false)
# SQLite = локальная разработка
# PostgreSQL = продакшен (Supabase)
USE_SQLITE=true

# Строка подключения к PostgreSQL (Supabase)
# Settings → Database → Connection string → Transaction mode (port 6543)
DATABASE_URL=

# Telegram ID админов (через запятую)
ADMIN_IDS=
